        elseif inlist 'smer' 'S'
            droprelloc 0 1
        elseif inlist 'smer' 'E'
            droprelloc 1 0
        elseif inlist 'smer' 'W'
            droprelloc -1 0
        endif
        wait 200
    endif

    if findtype '6586' true as 'base6586'
        ignore 'base6586'
        while findtype '6586' true as 'ore'
            lift 'ore' 60000
            drop 'base6586' 0 0 0
            wait 200
            ignore 'ore'
        endwhile
        clearignore
        lift 'base6586' 60000
        if inlist 'smer' 'N'
            droprelloc 0 -1
        elseif inlist 'smer' 'S'
            droprelloc 0 1
        elseif inlist 'smer' 'E'
            droprelloc 1 0
        elseif inlist 'smer' 'W'
            droprelloc -1 0
        endif
        wait 200
    endif

    clearignore
    overhead '[OK] Dalsi radka' 66
    clearsysmsg
endwhile
